{
  "name": "salonx-flightdeck",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm -F salonx-flightdeck-dashboard dev",
    "build": "pnpm -F salonx-flightdeck-dashboard build",
    "typecheck": "pnpm -r typecheck",
    "poll": "pnpm -F @flightdeck/poller start",
