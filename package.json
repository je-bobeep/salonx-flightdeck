    "check:lark-schema": "tsx scripts/check-lark-schema.mjs"
  },
  "engines": {
    "node": ">=20.11"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  },
  "packageManager": "pnpm@9.12.1"
}
